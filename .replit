modules = ["java-graalvm22.3", "nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build APK"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd web && pnpm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Build APK"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export JAVA_HOME=~/jdk21 && export PATH=$JAVA_HOME/bin:$PATH && export ANDROID_SDK_ROOT=~/Android/Sdk && export ANDROID_HOME=~/Android/Sdk && export SKIP_SETUP_ERRORS=1 && bash scripts/build-jamii.sh latestArm64Debug"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]
